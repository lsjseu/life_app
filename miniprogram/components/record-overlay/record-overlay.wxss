.overlay {
  position: fixed;
  inset: 0;
  z-index: 99;
}

.mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.36);
}

.panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 86vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #f5f5f5;
  box-shadow: 0 -12rpx 32rpx rgba(0, 0, 0, 0.16);
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  background: #ffffff;
}

.title {
  color: #212121;
  font-size: 34rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 6rpx;
  color: #757575;
  font-size: 22rpx;
}

.close {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 50%;
  background: #f5f5f5;
  color: #757575;
  line-height: 64rpx;
}

.messages {
  height: calc(86vh - 480rpx - env(safe-area-inset-bottom));
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}

.message {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #4caf50;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user .avatar {
  background: #212121;
}

.bubble {
  max-width: 76%;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #212121;
  font-size: 28rpx;
  line-height: 42rpx;
  white-space: pre-wrap;
}

.user .bubble {
  background: #4caf50;
  color: #ffffff;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.actions button {
  margin: 0;
  border: 1rpx solid #4caf50;
  color: #4caf50;
  background: #ffffff;
}

.time {
  margin-top: 8rpx;
  color: #bdbdbd;
  font-size: 20rpx;
}

.thinking {
  display: inline-flex;
  margin-left: 72rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #757575;
}

.tips {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 32rpx;
  background: #ffffff;
  overflow-x: auto;
}

.tips button {
  margin: 0;
  color: #388e3c;
  background: #e8f5e9;
}

.image-preview {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 32rpx;
  background: #ffffff;
}

.image-preview image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
}

.input-bar {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-height: 252rpx;
  padding: 18rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-sizing: border-box;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.icon-button {
  width: 112rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 24rpx;
  line-height: 72rpx;
  flex-shrink: 0;
}

.text-input {
  width: 100%;
  height: 128rpx;
  min-height: 128rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #212121;
  font-size: 28rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}

.input-placeholder {
  color: #9e9e9e;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.submit-button.disabled {
  background: #a5d6a7;
}
