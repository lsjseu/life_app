.overlay {
  position: fixed;
  inset: 0;
  z-index: 99;
}

.mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.36);
}

.panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 82vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #f5f5f5;
  box-shadow: 0 -12rpx 32rpx rgba(0, 0, 0, 0.16);
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  background: #ffffff;
}

.title {
  color: #212121;
  font-size: 34rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 6rpx;
  color: #757575;
  font-size: 22rpx;
}

.close {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 50%;
  background: #f5f5f5;
  color: #757575;
  line-height: 64rpx;
}

.messages {
  height: calc(82vh - 270rpx);
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}

.message {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #4caf50;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user .avatar {
  background: #212121;
}

.bubble {
  max-width: 76%;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #212121;
  font-size: 28rpx;
  line-height: 42rpx;
  white-space: pre-wrap;
}

.user .bubble {
  background: #4caf50;
  color: #ffffff;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.actions button {
  margin: 0;
  border: 1rpx solid #4caf50;
  color: #4caf50;
  background: #ffffff;
}

.time {
  margin-top: 8rpx;
  color: #bdbdbd;
  font-size: 20rpx;
}

.thinking {
  display: inline-flex;
  margin-left: 72rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #757575;
}

.tips {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 32rpx;
  background: #ffffff;
  overflow-x: auto;
}

.tips button {
  margin: 0;
  color: #388e3c;
  background: #e8f5e9;
}

.image-preview {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 32rpx;
  background: #ffffff;
}

.image-preview image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
}

.icon-button {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 50%;
  background: #4caf50;
  color: #ffffff;
  line-height: 72rpx;
}

.input-bar input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 36rpx;
  background: #f5f5f5;
  font-size: 28rpx;
}

.send {
  width: 104rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background: #4caf50;
  color: #ffffff;
  line-height: 72rpx;
}

