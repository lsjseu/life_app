<view class="page">
  <view class="page-header">
    <view class="title">健康报告</view>
    <view class="subtitle">先看报告，再有针对性地问顾问</view>
  </view>

  <view class="type-switch card">
    <button class="{{activeType === 'daily' ? 'active' : ''}}" data-type="daily" bindtap="switchType">日报</button>
    <button class="{{activeType === 'weekly' ? 'active' : ''}}" data-type="weekly" bindtap="switchType">周报</button>
    <button class="{{activeType === 'monthly' ? 'active' : ''}}" data-type="monthly" bindtap="switchType">月报</button>
  </view>

  <view wx:if="{{currentReport}}" class="latest card">
    <view class="latest-top">
      <view>
        <view class="report-title">{{currentReport.title}}</view>
        <view class="muted">{{currentReport.period_start}} 至 {{currentReport.period_end}}</view>
      </view>
      <view class="score">{{currentReport.score}}</view>
    </view>
    <view class="summary">{{currentReport.summary}}</view>
    <view class="sections">
      <view wx:for="{{currentReport.content.sections}}" wx:key="title" class="section">
        <view class="section-name">{{item.title}}</view>
        <view wx:for="{{item.items}}" wx:for-item="line" wx:key="*this" class="section-line">• {{line}}</view>
      </view>
    </view>
  </view>

  <view class="section-title">历史报告</view>
  <view class="history">
    <view wx:for="{{activeReports}}" wx:key="id" class="history-item card">
      <view>
        <view class="history-title">{{item.title}}</view>
        <view class="muted">{{item.created_at}}</view>
      </view>
      <view class="mini-score">{{item.score}}</view>
    </view>
  </view>

  <view wx:if="{{!currentReport && !loading}}" class="empty card">
    <view>还没有{{typeLabels[activeType]}}</view>
    <view class="muted">报告会由后台每天自动生成</view>
  </view>
</view>
