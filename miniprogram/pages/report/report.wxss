.page-header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  color: #757575;
}

.type-switch {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 8rpx;
}

.type-switch button {
  min-height: 68rpx;
  border-radius: 8rpx;
  background: transparent;
  color: #757575;
  font-size: 26rpx;
  line-height: 68rpx;
}

.type-switch button.active {
  background: #4caf50;
  color: #ffffff;
}

.latest {
  margin-top: 28rpx;
  padding: 32rpx;
}

.latest-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-title,
.history-title {
  font-size: 32rpx;
  font-weight: 700;
}

.score {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e8f5e9;
  color: #4caf50;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 112rpx;
  text-align: center;
}

.summary {
  margin-top: 24rpx;
  color: #212121;
  line-height: 42rpx;
}

.sections {
  margin-top: 24rpx;
}

.section {
  padding: 20rpx 0;
  border-top: 1rpx solid #e0e0e0;
}

.section-name {
  font-weight: 700;
  margin-bottom: 10rpx;
}

.section-line {
  color: #757575;
  line-height: 38rpx;
}

.history {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.mini-score {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #4caf50;
  color: #ffffff;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.empty {
  padding: 56rpx;
  text-align: center;
}
