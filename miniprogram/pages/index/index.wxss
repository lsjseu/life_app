.home {
  padding-bottom: 48rpx;
}

.hero {
  padding: 36rpx;
  background: linear-gradient(135deg, #4caf50, #81c784);
  color: #ffffff;
}

.hello {
  font-size: 40rpx;
  font-weight: 700;
}

.greeting {
  margin-top: 12rpx;
  opacity: 0.92;
  line-height: 40rpx;
}

.score-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 36rpx;
}

.score {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.hero .muted {
  color: rgba(255, 255, 255, 0.8);
}

.streak {
  display: flex;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
}

.today-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.metric {
  padding: 24rpx 16rpx;
  text-align: center;
}

.metric-icon {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 14rpx;
  border-radius: 50%;
  line-height: 64rpx;
}

.diet {
  background: #fff3e0;
}

.sport {
  background: #e3f2fd;
}

.health {
  background: #ffebee;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 4rpx;
  color: #757575;
  font-size: 22rpx;
}

.record-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  height: 176rpx;
  border-radius: 24rpx;
  background: #4caf50;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(76, 175, 80, 0.28);
}

.record-icon {
  font-size: 48rpx;
  line-height: 48rpx;
}

.record-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 400;
  opacity: 0.86;
}

.quick-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.quick-row button {
  border-radius: 16rpx;
  background: #ffffff;
  color: #388e3c;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.record-type {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.record-type.diet {
  background: #ff9800;
}

.record-type.exercise {
  background: #2196f3;
}

.record-type.health {
  background: #f44336;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 30rpx;
  font-weight: 700;
}

.record-sub {
  margin-top: 6rpx;
  color: #757575;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  color: #bdbdbd;
  font-size: 20rpx;
}

.empty {
  padding: 48rpx;
  color: #757575;
  text-align: center;
}

.empty button {
  margin-top: 24rpx;
  background: #4caf50;
  color: #ffffff;
}

